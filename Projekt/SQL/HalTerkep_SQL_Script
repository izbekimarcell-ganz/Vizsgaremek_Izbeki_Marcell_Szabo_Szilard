-- Felhasználók
CREATE TABLE dbo.Felhasznalo
(
    FelhasznaloId      INT IDENTITY(1,1) NOT NULL CONSTRAINT PK_Felhasznalo PRIMARY KEY,
    Felhasznalonev     NVARCHAR(50)  NOT NULL,
    Email              NVARCHAR(100) NOT NULL,
    JelszoHash         NVARCHAR(255) NOT NULL,
    ProfilKepUrl       NVARCHAR(MAX) NULL,
    Bemutatkozas       NVARCHAR(1000) NULL,
    BiztonsagiKerdes   NVARCHAR(200) NULL,
    BiztonsagiValaszHash NVARCHAR(255) NULL,
    Admin              BIT           NOT NULL CONSTRAINT DF_Felhasznalo_Admin DEFAULT (0),
    Privat             BIT           NOT NULL CONSTRAINT DF_Felhasznalo_Privat DEFAULT (0),
    Letrehozva         DATETIME2     NOT NULL CONSTRAINT DF_Felhasznalo_Letrehozva DEFAULT (SYSUTCDATETIME()),
    Aktiv              BIT           NOT NULL CONSTRAINT DF_Felhasznalo_Aktiv DEFAULT (1)
);
GO

CREATE UNIQUE INDEX UX_Felhasznalo_Felhasznalonev ON dbo.Felhasznalo(Felhasznalonev);
CREATE UNIQUE INDEX UX_Felhasznalo_Email          ON dbo.Felhasznalo(Email);
CREATE INDEX IX_Felhasznalo_Admin                 ON dbo.Felhasznalo(Admin);
GO

-- Barátkérelmek
CREATE TABLE dbo.BaratKerelem
(
    BaratKerelemId              INT IDENTITY(1,1) NOT NULL CONSTRAINT PK_BaratKerelem PRIMARY KEY,
    KezdemenyezoFelhasznaloId   INT NOT NULL,
    CimzettFelhasznaloId        INT NOT NULL,
    FelhasznaloEgyId AS (
        CASE
            WHEN KezdemenyezoFelhasznaloId < CimzettFelhasznaloId THEN KezdemenyezoFelhasznaloId
            ELSE CimzettFelhasznaloId
        END
    ) PERSISTED,
    FelhasznaloKettoId AS (
        CASE
            WHEN KezdemenyezoFelhasznaloId < CimzettFelhasznaloId THEN CimzettFelhasznaloId
            ELSE KezdemenyezoFelhasznaloId
        END
    ) PERSISTED,
    Allapot                     NVARCHAR(20) NOT NULL,
    Letrehozva                  DATETIME2(0) NOT NULL CONSTRAINT DF_BaratKerelem_Letrehozva DEFAULT (SYSUTCDATETIME()),
    Valaszolva                  DATETIME2(0) NULL,
    CONSTRAINT CK_BaratKerelem_Allapot CHECK (Allapot IN (N'pending', N'accepted', N'rejected')),
    CONSTRAINT CK_BaratKerelem_Onmaga CHECK (KezdemenyezoFelhasznaloId <> CimzettFelhasznaloId),
    CONSTRAINT UQ_BaratKerelem_Pair UNIQUE (FelhasznaloEgyId, FelhasznaloKettoId),
    CONSTRAINT FK_BaratKerelem_Kezdemenyezo FOREIGN KEY (KezdemenyezoFelhasznaloId)
        REFERENCES dbo.Felhasznalo(FelhasznaloId),
    CONSTRAINT FK_BaratKerelem_Cimzett FOREIGN KEY (CimzettFelhasznaloId)
        REFERENCES dbo.Felhasznalo(FelhasznaloId)
);
GO

CREATE INDEX IX_BaratKerelem_Cimzett_Allapot
    ON dbo.BaratKerelem(CimzettFelhasznaloId, Allapot, Letrehozva DESC);
GO

