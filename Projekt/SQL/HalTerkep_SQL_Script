    /* =========================================================
       7.7) Minimális fórum és fogás minta
       ========================================================= */
    IF NOT EXISTS (SELECT 1 FROM dbo.ForumTema)
    BEGIN
        INSERT INTO dbo.ForumTema (FelhasznaloId, Cim, Letrehozva)
        VALUES (@TesztId, N'Bemutatkozás', SYSUTCDATETIME());

        DECLARE @TemaId INT = SCOPE_IDENTITY();

        INSERT INTO dbo.ForumHozzaszolas (TemaId, FelhasznaloId, Szoveg, KepUrl, Letrehozva)
        VALUES (@TemaId, @TesztId, N'Sziasztok! Ez egy minta hozzászólás.', NULL, SYSUTCDATETIME());
    END

    IF NOT EXISTS (SELECT 1 FROM dbo.FogasNaplo)
    BEGIN
        INSERT INTO dbo.FogasNaplo
            (FelhasznaloId, HalfajId, VizteruletId, FogasIdeje, SulyKg, HosszCm, FotoUrl, Megjegyzes)
        VALUES
            (@TesztId, @PontyId, @RsdId, DATEADD(day, -7, SYSUTCDATETIME()), 3.50, 52, NULL, N'Minta fogás'),
            (@TesztId, @CsukaId, @DunaId, DATEADD(day, -2, SYSUTCDATETIME()), 2.10, 65, NULL, N'Minta fogás');
    END

    COMMIT TRAN;
END TRY
BEGIN CATCH
    IF @@TRANCOUNT > 0
        ROLLBACK TRAN;

    DECLARE @Err NVARCHAR(4000) = ERROR_MESSAGE();
    RAISERROR(N'Hiba az adatfeltöltés során: %s', 16, 1, @Err);
END CATCH;
